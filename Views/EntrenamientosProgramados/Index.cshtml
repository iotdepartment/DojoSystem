@model IEnumerable<TrainingsDashboard.Models.EntrenamientosProgramados>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

<div class="container-fluid">
    <div class="card mb-4 p-3 style-glass">
        <h2 class="m-0 text-start fw-bold">Programación de Entrenamientos</h2>
    </div>
    <div class="card border style-glass p-3">
        <div class="row mb-4 align-items-center">
            <div class="col-auto">
                <button class="btn btn-success shadow-lg rounded-pill px-4" data-bs-toggle="modal" data-bs-target="#ModalNuevaProgramacion">
                    <i class="fas fa-calendar-plus"></i> Programar Entrenamiento
                </button>
            </div>
            <div class="col-auto">
                <a asp-action="ExportarExcel" asp-controller="EntrenamientosProgramados" class="btn btn-primary shadow-lg rounded-pill px-4">
                    <i class="fas fa-file-excel me-1"></i> Exportar Excel
                </a>
            </div>
            <div class="col">
                <input type="text" id="searchInput" class="form-control shadow-lg rounded-pill" placeholder="Buscar por entrenamiento...">
            </div>
        </div>

        <!-- SECCIÓN DE ALERTAS CON AUTOCIERRE -->
        @if (TempData["MensajeExito"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show rounded-3 shadow-sm mb-3 alert-autocierre" role="alert">
                <i class="fas fa-check-circle me-2"></i> @TempData["MensajeExito"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        @if (TempData["MensajeAdvertencia"] != null)
        {
            <div class="alert alert-warning alert-dismissible fade show rounded-3 shadow-sm mb-3 alert-autocierre" role="alert">
                <div class="fw-bold mb-1"><i class="fas fa-exclamation-triangle me-2"></i> @TempData["MensajeAdvertencia"]</div>
                @if (TempData["ListaRepetidos"] is List<string> repetidos)
                {
                    <ul class="mb-0 ps-3 small">
                        @foreach (var emp in repetidos)
                        {
                            <li>@emp</li>
                        }
                    </ul>
                }
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        <!-- CONTENEDOR AGRUPADO -->
        <div class="row g-4 align-content-center" id="programacionContainer">
            @{
                var gruposProgramados = Model
                .GroupBy(p => new { p.EntrenamientoID, Fecha = p.FechaProgramacion?.Date })
                .OrderByDescending(g => g.Key.Fecha);

                var listaCursosCompleta = ViewBag.EntrenamientosCompletos as List<TrainingsDashboard.Models.Entrenamientos> ?? new List<TrainingsDashboard.Models.Entrenamientos>();
            }

            @foreach (var grupo in gruposProgramados)
            {
                var infoCurso = listaCursosCompleta.FirstOrDefault(x => x.Id == grupo.Key.EntrenamientoID);
                var entrenamientoNombre = infoCurso?.Nombre ?? "Sin Curso";
                var entrenamientoDesc = infoCurso?.Descripcion ?? "Sin descripción disponible.";
                var fechaFormateada = grupo.Key.Fecha?.ToString("dd/MM/yyyy") ?? "-";

                var totalInscritos = grupo.Count();
                var limiteCurso = infoCurso?.Limite ?? 0;
                int estatusGrupo = grupo.First().Status ?? 1;

                var cupoClase = infoCurso?.Limite.HasValue == true && totalInscritos >= infoCurso.Limite.Value && infoCurso.Limite.Value > 0
                ? "text-danger fw-bold"
                : "text-success";

                // PROYECCIÓN ACTUALIZADA: Incluimos la fecha de programación en el objeto JSON
                var listaEmpleadosJson = System.Text.Json.JsonSerializer.Serialize(grupo.Select(p => new
                {
                    id = p.ID,
                    empleado = (ViewBag.ListaEmpleados as List<SelectListItem>)?.FirstOrDefault(x => x.Value == p.EmpleadoID?.ToString())?.Text ?? "Sin Empleado",
                    area = (ViewBag.ListaAreas as List<SelectListItem>)?.FirstOrDefault(x => x.Value == p.AreaID?.ToString())?.Text ?? "S/A",
                    status = p.Status ?? 1,
                    fechaProg = p.FechaProgramacion?.ToString("yyyy-MM-dd") // <-- AGREGADO: Fecha en formato ISO para el cálculo de tiempo
                }));


                <div class="col-12 col-sm-6 col-md-4 col-lg-3 programacion-card" data-search-course="@entrenamientoNombre.ToLower()">
                    <div class="card card-area p-3 text-center position-relative h-100 d-flex flex-column justify-content-between">
                        <div>
                            <button class="settings-btn">
                                <i class="fas fa-cog"></i>
                            </button>

                            <div class="settings-menu">
                                @{
                                    var idsGrupo = string.Join(",", grupo.Select(x => x.ID));
                                }
                                <a href="#" class="delete-programacion text-danger" data-id="@idsGrupo" data-nombre="@entrenamientoNombre (@fechaFormateada)">
                                    <i class="fas fa-trash"></i> Eliminar Grupo
                                </a>
                            </div>

                            <div class="my-2 text-primary">
                                <i class="fas fa-graduation-cap fa-2x"></i>
                            </div>

                            <div class="card-body p-1 text-start">
                                <h6 class="fw-bold target-course text-center text-primary mb-1">@entrenamientoNombre</h6>
                                <p class="text-dark extra-small text-center mb-2 text-truncate" title="@entrenamientoDesc" style="font-size: 0.75rem; font-style: italic;">
                                    Descripcion: @entrenamientoDesc
                                </p>

                                <p class="text-dark small text-center mb-2 fw-bold py-1 rounded">
                                    Fecha Programada: <i class="far fa-calendar-alt me-1"></i> @fechaFormateada
                                </p>

                                <div class="d-flex justify-content-between align-items-center mb-3 px-2 py-1 rounded">
                                    <span class="small fw-bold text-black">Cupo del Curso:</span>
                                    <span class="small @cupoClase">
                                        <i class="fas fa-users me-1"></i> @totalInscritos / @(infoCurso?.Limite?.ToString() ?? "0")
                                    </span>
                                </div>
                            </div>
                        </div>

                        <!-- Sección de acciones de la tarjeta -->
                        <div>
                            <!-- BOTÓN PARA ABRIR EL MODAL DE DETALLES DEL PERSONAL -->
                            <button type="button" class="btn btn-outline-primary btn-sm rounded-pill w-100 mb-2 btn-ver-personal"
                                    data-curso="@entrenamientoNombre"
                                    data-fecha="@fechaFormateada"
                                    data-empleados='@listaEmpleadosJson'>
                                <i class="fas fa-users me-1"></i> Ver Personal Inscrito
                            </button>

                            @if (estatusGrupo == 1)
                            {
                                <span class="badge bg-warning text-dark rounded-pill w-100 p-2">Programado</span>
                            }
                            else if (estatusGrupo == 2)
                            {
                                <span class="badge bg-success rounded-pill w-100 p-2">Asistió</span>
                            }
                            else
                            {
                                <span class="badge bg-danger rounded-pill w-100 p-2">Cancelado</span>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<!-- NUEVO MODAL: LISTA DE PERSONAL INSCRITO -->
<div class="modal fade" id="ModalVerPersonal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
        <!-- <-- Cambio aquí -->
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header bg-dark text-white rounded-top-4 p-3">
                <h5 class="modal-title fw-bold"><i class="fas fa-users me-2"></i>Personal Inscrito</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <div class="mb-3 border-bottom pb-2">
                    <h6 class="fw-bold text-primary m-0" id="modalPersonalCurso">Curso</h6>
                    <small class="text-muted fw-bold" id="modalPersonalFecha"><i class="far fa-calendar-alt me-1"></i> Fecha</small>
                </div>
                <div id="modalContenedorLista" class="list-group list-group-flush">
                    <!-- Los empleados se inyectarán aquí dinámicamente -->
                </div>
            </div>
            <div class="modal-footer border-0 bg-light rounded-bottom-4">
                <button type="button" class="btn btn-secondary rounded-pill px-4" data-bs-dismiss="modal">Cerrar</button>
            </div>
        </div>
    </div>
</div>


<!-- MODAL: CONFIRMAR ELIMINACIÓN (CANCELACIÓN DE PROGRAMACIÓN GRUPAL) -->
<div class="modal fade" id="ModalEliminarProgramacion" tabindex="-1" aria-labelledby="ModalEliminarProgramacionLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">

            <!-- Encabezado -->
            <div class="modal-header bg-danger text-white rounded-top-4 p-3">
                <h5 class="modal-title fw-bold" id="ModalEliminarProgramacionLabel">
                    <i class="fas fa-calendar-times me-2"></i>Eliminar Programación Grupal
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <!-- Cuerpo del Modal -->
            <div class="modal-body p-4">
                <!-- ID Oculto que procesa el Script de jQuery (Ahora almacena un string de IDs) -->
                <input type="hidden" id="DeleteID">

                <!-- Mensaje Dinámico inyectado por JavaScript -->
                <p id="deleteMessage" class="fs-5 mb-1 text-dark"></p>
                <small class="text-muted"><i class="fas fa-info-circle me-1"></i> Esta acción eliminará a todos los empleados inscritos en este bloque.</small>
            </div>

            <!-- Pie del Modal / Botones de Acción -->
            <div class="modal-footer border-0 p-3 bg-light rounded-bottom-4">
                <button type="button" class="btn btn-danger rounded-pill px-4 fw-bold" id="btnConfirmDelete">Eliminar Grupo</button>
                <button type="button" class="btn btn-secondary rounded-pill px-4" data-bs-dismiss="modal">Cancelar</button>
            </div>
        </div>
    </div>
</div>


<!-- MODAL: CREAR NUEVA PROGRAMACIÓN MÚLTIPLE (MULTI-ÁREA CON PREVIO AGRUPADO) -->
<div class="modal fade" id="ModalNuevaProgramacion" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header bg-primary text-white rounded-top-4 p-3">
                <h5 class="modal-title fw-bold"><i class="fas fa-calendar-plus me-2"></i>Programación Grupal</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="Crear" asp-controller="EntrenamientosProgramados" method="post" id="formProgramacionGrupal">
                @Html.AntiForgeryToken()
                <div class="modal-body p-4">

                    <!-- FILA SUPERIOR: CURSO Y FECHA -->
                    <div class="row mb-3">
                        <div class="col-12 col-md-6 mb-3 mb-md-0">
                            <label class="form-label fw-bold">Entrenamiento / Curso</label>
                            <select name="EntrenamientoID" class="form-select rounded-pill" asp-items="ViewBag.ListaEntrenamientos" required>
                                <option value="" selected disabled>-- Selecciona el Curso --</option>
                            </select>
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label fw-bold">Fecha de Programación</label>
                            <input type="date" name="FechaProgramacion" class="form-control rounded-pill" required />
                        </div>
                    </div>

                    <hr class="my-3">

                    <!-- SECCIÓN PRINCIPAL: DOS COLUMNAS -->
                    <div class="row">
                        <!-- COLUMNA IZQUIERDA: BUSCADOR Y CARGA -->
                        <div class="col-12 col-md-6 border-end">
                            <div class="mb-2">
                                <label class="form-label fw-bold text-primary small uppercase"><i class="fas fa-search me-1"></i> 1. Cargar por Área</label>
                                <!-- Busca tu selectArea y agrégale el atributo disabled por defecto -->
                                <select id="selectArea" class="form-select rounded-pill form-select-sm" disabled>
                                    <option value="" selected>-- Selecciona un Área --</option>
                                    @if (ViewBag.ListaAreas != null)
                                    {
                                        foreach (var area in ViewBag.ListaAreas)
                                        {
                                            <option value="@area.Value">@area.Text</option>
                                        }
                                    }
                                </select>
                            </div>

                            <div class="d-flex justify-content-between align-items-center mb-2 mt-3">
                                <span class="small fw-bold text-muted">Disponibles en Pantalla</span>
                                <div class="form-check" id="contenedorSeleccionarTodos" style="display: none;">
                                    <input class="form-check-input" type="checkbox" id="chkSeleccionarTodos">
                                    <label class="form-check-label small text-muted" for="chkSeleccionarTodos">Marcar Todos</label>
                                </div>
                            </div>

                            <!-- Lista de selección original -->
                            <div class="border rounded-3 p-2 bg-light" style="max-height: 220px; overflow-y: auto;">
                                <div id="contenedorListaEmpleados" class="list-group list-group-flush">
                                    <div class="text-muted small p-4 text-center" id="placeholderLista">
                                        Selecciona un área arriba para traer su personal.
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- COLUMNA DERECHA: REVISIÓN VISUAL DE AGREGADOS Y AGRUPADOS -->
                        <div class="col-12 col-md-6 mt-3 mt-md-0">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <label class="form-label fw-bold text-success small uppercase mb-0">
                                    <i class="fas fa-users-cog me-1"></i> 2. Grupo Final (<span id="contadorSeleccionados">0</span>)
                                </label>
                                <button type="button" id="btnLimpiarTodo" class="btn btn-link p-0 text-danger small text-decoration-none fw-bold" style="display:none; font-size: 0.8rem;">
                                    <i class="fas fa-trash-alt"></i> Limpiar Todo
                                </button>
                            </div>

                            <!-- CONTENEDOR DE LA LISTA RESUMEN AGRUPADA -->
                            <div class="border rounded-3 p-3 bg-white" style="max-height: 260px; overflow-y: auto;" id="contenedorGrupoFinal">
                                <div class="text-muted small p-4 text-center" id="placeholderGrupoFinal">
                                    Marca las casillas de la izquierda para armar el grupo aquí.
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Contenedor dinámico de inputs ocultos que viajarán a C# -->
                    <div id="inputsOcultosEmpleados"></div>

                </div>
                <div class="modal-footer border-0 p-3 bg-light rounded-bottom-4">
                    <button type="submit" class="btn btn-success rounded-pill px-4 fw-bold">Programar Grupo</button>
                    <button type="button" class="btn btn-secondary rounded-pill px-4" data-bs-dismiss="modal">Cancelar</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://jquery.com"></script>
    <script>
        $(document).ready(function () {
            initBuscador();
            initMenuFlotante();
            initModuloEliminar();
            initSupervisorAutomatico();
        });

        // ==========================================
        // NUEVO: DETECTAR EMPLEADO Y TRAER SU SUPERVISOR
        // ==========================================
        function initSupervisorAutomatico() {
            $('#create_EmpleadoID').on('change', function () {
                var empleadoId = $(this).val();

                if (empleadoId) {
                    // Hacemos una consulta rápida al servidor en segundo plano
                    $.ajax({
                        url: '/EntrenamientosProgramados/ObtenerSupervisorEmpleado',
                        type: 'GET',
                        data: { empleadoId: empleadoId },
                        success: function (res) {
                            // Guardamos el ID del supervisor del empleado en el input oculto
                            $('#create_SupervisorID').val(res.supervisorId);
                        },
                        error: function () {
                            // En caso de falla, asegurar que envíe 0 o NA
                            $('#create_SupervisorID').val(0);
                        }
                    });
                }
            });
        }


        // ==========================================
        // 1. FILTRADO EN TIEMPO REAL
        // ==========================================
        function initBuscador() {
            $("#searchInput").on("keyup", function () {
                var value = $(this).val().toLowerCase();
                $(".programacion-card").filter(function () {
                    var textCourse = $(this).find(".target-course").text().toLowerCase();
                    var textEmp = $(this).find(".target-emp").text().toLowerCase();
                    $(this).toggle(textCourse.indexOf(value) > -1 || textEmp.indexOf(value) > -1);
                });
            });
        }

        // ==========================================
        // 2. INTERFAZ (BOTÓN DE ENGRANE)
        // ==========================================
        function initMenuFlotante() {
            $(document).on('click', '.settings-btn', function (e) {
                e.stopPropagation();
                $('.settings-menu').not($(this).next()).hide();
                $(this).next().toggle();
            });
            $(document).on('click', function () {
                $('.settings-menu').hide();
            });
        }

        function initModuloEliminar() {
            // Evento al presionar el botón de eliminar de la tarjeta agrupada
            $(document).on('click', '.delete-programacion', function (e) {
                e.preventDefault();
                var id = $(this).data('id'); // Recupera la cadena "12,13,14..."
                var nombre = $(this).data('nombre'); // Recupera "NombreCurso (Fecha)"

                $('#DeleteID').val(id);
                $('#deleteMessage').html('¿Estás seguro de que deseas eliminar **todo el grupo programado** para el entrenamiento: <strong class="text-danger">' + nombre + '</strong>?');

                var deleteModal = new bootstrap.Modal(document.getElementById('ModalEliminarProgramacion'));
                deleteModal.show();
            });

            // Confirmación final dentro del modal
            $('#btnConfirmDelete').on('click', function () {
                var idsString = $('#DeleteID').val(); // Captura la cadena de IDs
                var $btn = $(this);

                $btn.prop('disabled', true).text('Eliminar de grupo...');

                $.ajax({
                    url: '/EntrenamientosProgramados/EliminarGrupo', // Apunta al nuevo método masivo
                    type: 'POST',
                    data: { idsString: idsString }, // Enviamos el string al servidor
                    success: function () {
                        window.location.reload();
                    },
                    error: function () {
                        alert('Ocurrió un error al intentar eliminar el grupo de registros.');
                        $btn.prop('disabled', false).text('Eliminar Grupo');
                    }
                });
            });
        }

    </script>

    <script>
            $(document).ready(function () {
        const $selectArea = $('#selectArea');
        const $contenedorLista = $('#contenedorListaEmpleados');
        const $contenedorGrupoFinal = $('#contenedorGrupoFinal');
        const $inputsOcultos = $('#inputsOcultosEmpleados');
        const $contador = $('#contadorSeleccionados');
        const $chkSeleccionarTodos = $('#chkSeleccionarTodos');
        const $contenedorTodos = $('#contenedorSeleccionarTodos');
        const $btnLimpiarTodo = $('#btnLimpiarTodo');

        // Selectores del encabezado principal
        const $selectCurso = $('select[name="EntrenamientoID"]');
        const $inputFecha = $('input[name="FechaProgramacion"]');

        let idsCargadosEnPantalla = new Set();

        // ===================================================================================
        // FLUJO CONTROLADO: Activar o resetear el selector de áreas según los datos superiores
        // ===================================================================================
        function verificarCamposPrincipales() {
            const cursoId = $selectCurso.val();
            const fechaVal = $inputFecha.val();

            if (cursoId && fechaVal) {
                $selectArea.removeAttr('disabled'); // Desbloquear áreas si ya hay curso y fecha
            } else {
                $selectArea.attr('disabled', 'disabled'); // Bloquear si falta alguno
                resetearContenedoresPorCambio();
            }
        }

        // Escuchar si cambian el curso o la fecha en la parte de arriba
        $selectCurso.on('change', verificarCamposPrincipales);
        $inputFecha.on('change', verificarCamposPrincipales);

        // Rutina de limpieza inmediata si el usuario cambia el curso o la fecha a mitad de la operación
        function resetearContenedoresPorCambio() {
            $contenedorLista.empty();
            $contenedorGrupoFinal.empty();
            idsCargadosEnPantalla.clear();
            $contenedorTodos.hide();
            $btnLimpiarTodo.hide();
            $chkSeleccionarTodos.prop('checked', false);
            $selectArea.val("");

            $contenedorLista.html('<div class="text-muted small p-4 text-center" id="placeholderLista">Selecciona un área arriba para traer su personal.</div>');
            $contenedorGrupoFinal.html('<div class="text-muted small p-4 text-center" id="placeholderGrupoFinal">Marca las casillas de la izquierda para armar el grupo aquí.</div>');
            actualizarInputsYContador();
        }

        // ===================================================================================
        // 1. Cargar empleados desde el servidor (Izquierda - SOLO DISPONIBLES REALES)
        // ===================================================================================
        $selectArea.on('change', function () {
            const areaId = $(this).val();
            const areaNombre = $(this).find('option:selected').text();
            if (!areaId) return;

            const entrenamientoId = $selectCurso.val();
            const fechaProg = $inputFecha.val();

            $('#placeholderLista').remove();
            $contenedorTodos.show();
            $btnLimpiarTodo.show();

            const $spinner = $('<div id="tempSpinner" class="text-center p-2"><div class="spinner-border spinner-border-sm text-primary" role="status"></div> Buscando...</div>');
            $contenedorLista.append($spinner);

            $.ajax({
                url: '/EntrenamientosProgramados/ObtenerPorArea',
                type: 'GET',
                data: { areaId: areaId, entrenamientoId: entrenamientoId, fecha: fechaProg },
                success: function (empleados) {
                    $('#tempSpinner').remove();

                    if (empleados.length === 0) {
                        alert("No hay más empleados disponibles en esta área (o todos ya tienen programado este entrenamiento en esta fecha).");
                        evaluarEstadosVacios();
                        return;
                    }

                    empleados.forEach(emp => {
                        if (!idsCargadosEnPantalla.has(emp.id)) {
                            idsCargadosEnPantalla.add(emp.id);

                            const itemHtml = `
                                <label class="list-group-item d-flex align-items-center py-2 border-bottom" data-id="${emp.id}" id="item-disp-${emp.id}" style="cursor: pointer;">
                                    <input class="form-check-input me-3 chk-empleado" type="checkbox"
                                           value="${emp.id}"
                                           data-nombre="${emp.nombre}"
                                           data-num="${emp.numeroEmpleado ?? 'S/N'}"
                                           data-area-id="${areaId}"
                                           data-area-nombre="${areaNombre}"
                                           data-turno="${emp.turnoId ?? 0}">
                                    <div class="small text-truncate">
                                        <span class="fw-bold text-primary">#${emp.numeroEmpleado ?? 'S/N'}</span> - ${emp.nombre}
                                    </div>
                                </label>
                            `;
                            $contenedorLista.append(itemHtml);
                        }
                    });

                    const total = $('.chk-empleado').length;
                    const marcados = $('.chk-empleado:checked').length;
                    $chkSeleccionarTodos.prop('checked', total === marcados && total > 0);

                    $selectArea.val("");
                },
                error: function () {
                    $('#tempSpinner').remove();
                    alert("Error de red.");
                    evaluarEstadosVacios();
                }
            });
        });

        // ===================================================================================
        // 2. Evento al marcar/desmarcar casillas (Traspaso dinámico a la derecha)
        // ===================================================================================
        $contenedorLista.on('change', '.chk-empleado', function () {
            const $chk = $(this);
            const empId = $chk.val();
            const empNombre = $chk.data('nombre');
            const empNum = $chk.data('num');
            const areaId = $chk.data('area-id');
            const areaNombre = $chk.data('area-nombre');

            $('#placeholderGrupoFinal').remove();

            if ($chk.is(':checked')) {
                let $bloqueArea = $contenedorGrupoFinal.find(`#grupo-area-${areaId}`);

                if ($bloqueArea.length === 0) {
                    const estructuraAreaHtml = `
                        <div class="mb-3 bloque-area-final" id="grupo-area-${areaId}">
                            <div class="fw-bold text-dark border-bottom pb-1 small mb-1 d-flex align-items-center" style="font-size: 0.75rem;">
                                <i class="fas fa-folder-open text-warning me-2"></i> ${areaNombre}
                            </div>
                            <div class="lista-interna-area ps-2"></div>
                        </div>
                    `;
                    $contenedorGrupoFinal.append(estructuraAreaHtml);
                    $bloqueArea = $contenedorGrupoFinal.find(`#grupo-area-${areaId}`);
                }

                if ($bloqueArea.find(`#final-emp-${empId}`).length === 0) {
                    const empleadoFinalHtml = `
                        <div class="d-flex justify-content-between align-items-center mb-1 small text-muted badge-emp-final p-1 rounded bg-light" id="final-emp-${empId}">
                            <span class="text-truncate" style="max-width: 85%; font-size: 0.75rem;">
                                <span class="fw-bold text-secondary">#${empNum}</span> - ${empNombre}
                            </span>
                            <button type="button" class="btn-close p-0 btn-remover-emp" data-id="${empId}" style="font-size: 0.65rem; width: auto; height: auto;"></button>
                        </div>
                    `;
                    $bloqueArea.find('.lista-interna-area').append(empleadoFinalHtml);
                }

            } else {
                $contenedorGrupoFinal.find(`#final-emp-${empId}`).remove();
                limpiarBloquesAreasVacios();
            }

            const total = $('.chk-empleado').length;
            const marcados = $('.chk-empleado:checked').length;
            $chkSeleccionarTodos.prop('checked', total === marcados && total > 0);

            actualizarInputsYContador();
        });

        // 3. Botón "X" de remoción rápida desde la lista final (Derecha)
        $contenedorGrupoFinal.on('click', '.btn-remover-emp', function () {
            const empId = $(this).data('id');
            $contenedorLista.find(`#item-disp-${empId} .chk-empleado`).prop('checked', false).trigger('change');
        });

        // 4. Marcar todos los de la izquierda
        $chkSeleccionarTodos.on('change', function () {
            const estado = $(this).is(':checked');
            $('.chk-empleado').prop('checked', estado).trigger('change');
        });

        // 5. Botón Limpiar Todo
        $btnLimpiarTodo.on('click', function () {
            if (confirm("¿Vaciar por completo la selección actual?")) {
                resetearContenedoresPorCambio();
            }
        });

        // 6. Rutina para borrar títulos de áreas vacías
        function limpiarBloquesAreasVacios() {
            $('.bloque-area-final').each(function () {
                if ($(this).find('.badge-emp-final').length === 0) {
                    $(this).remove();
                }
            });
            if ($('.badge-emp-final').length === 0 && $contenedorGrupoFinal.find('#placeholderGrupoFinal').length === 0) {
                $contenedorGrupoFinal.html('<div class="text-muted small p-4 text-center" id="placeholderGrupoFinal">Marca las casillas de la izquierda para armar el grupo aquí.</div>');
            }
        }

        // 7. Evalúa si la lista de disponibles quedó vacía
        function evaluarEstadosVacios() {
            if ($contenedorLista.children('.list-group-item').length === 0) {
                $contenedorLista.html('<div class="text-muted small p-4 text-center" id="placeholderLista">Selecciona un área arriba para traer su personal.</div>');
                $contenedorTodos.hide();
                $btnLimpiarTodo.hide();
                $chkSeleccionarTodos.prop('checked', false);

            }
        }
                    // 8. Sincronizar inputs ocultos estructurados con índices mapeados para C#
            function actualizarInputsYContador() {
                $inputsOcultos.empty();
                const $seleccionados = $('.chk-empleado:checked');
                $contador.text($seleccionados.length);

                $seleccionados.each(function (index, elemento) {
                    const empleadoId = $(elemento).val();
                    const areaId = $(elemento).data('area-id');
                    const turnoId = $(elemento).data('turno');

                    // Aseguramos la estructura exacta indexada que requiere tu método POST Crear
                    const inputsHtml = `
                        <input type="hidden" name="EmpleadosIds[${index}]" value="${empleadoId}" />
                        <input type="hidden" name="AreasIds[${index}]" value="${areaId}" />
                        <input type="hidden" name="TurnosIds[${index}]" value="${turnoId}" />
                    `;
                    $inputsOcultos.append(inputsHtml);
                });
            }

            // 9. Limpiar completamente el modal al cerrarlo o cancelarlo
            $('#ModalNuevaProgramacion').on('hidden.bs.modal', function () {
                $selectCurso.val("");
                $inputFecha.val("");
                $selectArea.attr('disabled', 'disabled');
                resetearContenedoresPorCambio();
            });
        });
    </script>
    <script>
         var $ultimoBotonClickeado = null;

        $(document).ready(function () {
            // 1. Temporizador de 10 segundos para cerrar alertas automáticamente
            const $alertas = $('.alert-autocierre');
            if ($alertas.length > 0) {
                setTimeout(function () {
                    $alertas.each(function () {
                        const bAlert = bootstrap.Alert.getOrCreateInstance(this);
                        if (bAlert) bAlert.close();
                    });
                }, 10000);
            }

            // 2. Buscador en tiempo real por Entrenamiento
            $('#searchInput').on('keyup', function () {
                const query = $(this).val().toLowerCase().trim();

                $('.programacion-card').each(function () {
                    const $card = $(this);
                    const cursoTxt = $card.data('search-course') || '';

                    if (cursoTxt.includes(query) || query === "") {
                        $card.show();
                    } else {
                        $card.hide();
                    }
                });
            });

            // 3. EVENTO DINÁMICO: Cargar personal agrupado por área en el segundo modal
             $(document).on('click', '.btn-ver-personal', function () {
                // Guardamos la referencia nativa del botón de la tarjeta principal
                $ultimoBotonClickeado = this;

                const curso = $(this).data('curso');
                const fecha = $(this).data('fecha');
                let empleados = $(this).data('empleados');

                if (typeof empleados === 'string') {
                    try { empleados = JSON.parse(empleados); }
                    catch (e) { console.error("Error al parsear empleados:", e); empleados = []; }
                }

                $('#modalPersonalCurso').text(curso);
                $('#modalPersonalFecha').html(`<i class="far fa-calendar-alt me-1"></i> ${fecha}`);

                const $lista = $('#modalContenedorLista');
                $lista.empty();

                if (!empleados || empleados.length === 0) {
                    $lista.append('<div class="text-center text-muted py-3 small">No hay personal inscrito en este curso.</div>');
                } else {
                    const areasAgrupadas = {};
                    empleados.forEach(emp => {
                        const nombreArea = emp.area || "Sin Área Especificada";
                        if (!areasAgrupadas[nombreArea]) { areasAgrupadas[nombreArea] = []; }
                        areasAgrupadas[nombreArea].push(emp);
                    });

                    for (const area in areasAgrupadas) {
                        $lista.append(`
                            <div class="mt-3 mb-2 bg-light p-2 rounded-2 border-start border-primary border-3">
                                <span class="fw-bold text-secondary small text-uppercase"><i class="fas fa-layer-group me-1"></i> ${area}</span>
                                <span class="badge bg-secondary rounded-pill float-end small">${areasAgrupadas[area].length}</span>
                            </div>
                        `);

                        areasAgrupadas[area].forEach(emp => {
                            let badgeAyudaVisual = '';
                            let botonAsistencia = '';

                            let esVencido = false;
                            if (emp.fechaProg) {
                                const fechaProgramada = new Date(emp.fechaProg + 'T00:00:00');
                                const fechaHoy = new Date();
                                fechaHoy.setHours(0,0,0,0);
                                const diferenciaDias = Math.floor((fechaHoy.getTime() - fechaProgramada.getTime()) / (1000 * 60 * 60 * 24));
                                if (diferenciaDias > 7) { esVencido = true; }
                            }

                            if (parseInt(emp.status) === 2) {
                                badgeAyudaVisual = `<span class="badge bg-success-subtle text-success border border-success rounded-pill px-2 py-1 extra-small ms-2 span-badge-estado" style="font-size: 0.7rem;"><i class="fas fa-check-circle me-1"></i>Asistió</span>`;
                                botonAsistencia = `<span class="text-success small me-2"><i class="fas fa-check"></i> Listo</span>`;
                            } else if (parseInt(emp.status) === 1 && esVencido) {
                                badgeAyudaVisual = `<span class="badge bg-danger-subtle text-danger border border-danger rounded-pill px-2 py-1 extra-small ms-2 span-badge-estado" style="font-size: 0.7rem;"><i class="fas fa-exclamation-circle me-1"></i>Vencido</span>`;
                                botonAsistencia = `<button type="button" class="btn btn-sm btn-outline-success rounded-pill me-2 btn-marcar-asistencia" data-id="${emp.id}"><i class="fas fa-check"></i></button>`;
                            } else {
                                badgeAyudaVisual = `<span class="badge bg-warning-subtle text-warning border border-warning rounded-pill px-2 py-1 extra-small ms-2 span-badge-estado" style="font-size: 0.7rem;"><i class="far fa-clock me-1"></i>Pendiente</span>`;
                                botonAsistencia = `<button type="button" class="btn btn-sm btn-outline-success rounded-pill me-2 btn-marcar-asistencia" data-id="${emp.id}"><i class="fas fa-check"></i></button>`;
                            }

                            const filaHtml = `
                                <div class="list-group-item d-flex justify-content-between align-items-center py-2 px-0 border-bottom">
                                    <div class="me-2" style="max-width: 80%;">
                                        <div class="fw-bold text-dark small d-inline-flex align-items-center flex-wrap gap-1">
                                            <span>${emp.empleado}</span>
                                            ${badgeAyudaVisual}
                                        </div>
                                    </div>
                                    <div class="d-flex align-items-center flex-shrink-0">
                                        <div class="contenedor-accion-asistencia">
                                            ${botonAsistencia}
                                        </div>
                                        <button type="button" class="btn btn-sm btn-outline-danger rounded-pill btn-eliminar-empleado" data-id="${emp.id}">
                                            <i class="fas fa-trash-alt"></i>
                                        </button>
                                    </div>
                                </div>
                            `;
                            $lista.append(filaHtml);
                        });
                    }
                }

                const modalElement = document.getElementById('ModalVerPersonal');
                let modalPersonal = bootstrap.Modal.getInstance(modalElement) || new bootstrap.Modal(modalElement);
                modalPersonal.show();
            });

                    // ACCIÓN: Marcar Asistencia individual vía AJAX
        $(document).on('click', '.btn-marcar-asistencia', function () {
            const $btn = $(this);
            const idProgramacion = $btn.data('id');
            const $fila = $btn.closest('.list-group-item');

            if (confirm("¿Confirmar asistencia para este empleado?")) {
                $.post('/EntrenamientosProgramados/MarcarAsistencia', { id: idProgramacion })
                    .done(function (response) {
                        if (response.success) {
                            // 1. Cambio visual inmediato dentro del modal abierto
                            $fila.find('.span-badge-estado').replaceWith(`
                                <span class="badge bg-success-subtle text-success border border-success rounded-pill px-2 py-1 extra-small ms-2 span-badge-estado" style="font-size: 0.7rem;">
                                    <i class="fas fa-check-circle me-1"></i>Asistió
                                </span>`);
                            $btn.replaceWith(`<span class="text-success small me-2"><i class="fas fa-check"></i> Listo</span>`);

                            // 2. SOLUCIÓN REAL DEL PROBLEMA: Actualizar la memoria caché de jQuery en la tarjeta
                            if ($ultimoBotonClickeado) {
                                // Forzamos a jQuery a darnos su copia de memoria activa actual
                                let empleados = $($ultimoBotonClickeado).data('empleados');

                                // Si por alguna razón sigue siendo un string, lo transformamos a objeto interactivo
                                if (typeof empleados === 'string') {
                                    try { empleados = JSON.parse(empleados); } catch(e) { empleados = []; }
                                }

                                if (empleados && empleados.length > 0) {
                                    // Buscamos al alumno modificado
                                    const empModificar = empleados.find(e => e.id == idProgramacion);
                                    if (empModificar) {
                                        empModificar.status = 2; // <-- Cambiamos su estado a 2 (Asistió) en la memoria

                                        // CRÍTICO: Reinyectamos el objeto mutado de regreso en la memoria interna de jQuery
                                        $($ultimoBotonClickeado).data('empleados', empleados);

                                        // También respaldamos en el atributo de texto del HTML por seguridad
                                        $($ultimoBotonClickeado).attr('data-empleados', JSON.stringify(empleados));
                                    }
                                }
                            }
                        } else {
                            alert(response.message || "Error al registrar la asistencia.");
                        }
                    })
                    .fail(function () {
                        alert("Error de comunicación con el servidor.");
                    });
            }
        });

        // ACCIÓN: Eliminar empleado del curso vía AJAX
        $(document).on('click', '.btn-eliminar-empleado', function () {
            const $btn = $(this);
            const idProgramacion = $btn.data('id');
            const $fila = $btn.closest('.list-group-item');

            if (confirm("¿Estás seguro de que deseas eliminar a este empleado de este curso programado?")) {
                $.post('/EntrenamientosProgramados/EliminarEmpleadoCurso', { id: idProgramacion })
                    .done(function (response) {
                        if (response.success) {
                            // 1. Desvanecer la fila del modal
                            $fila.fadeOut(400, function () {
                                $(this).remove();
                                if ($('#modalContenedorLista').children('.list-group-item').length === 0) {
                                    $('#modalContenedorLista').append('<div class="text-center text-muted py-3 small">No hay personal inscrito en este curso.</div>');
                                }
                            });

                            // 2. SOLUCIÓN REAL DEL PROBLEMA: Removerlo de la memoria caché de jQuery en la tarjeta
                            if ($ultimoBotonClickeado) {
                                let empleados = $($ultimoBotonClickeado).data('empleados');

                                if (typeof empleados === 'string') {
                                    try { empleados = JSON.parse(empleados); } catch(e) { empleados = []; }
                                }

                                if (empleados && empleados.length > 0) {
                                    // Filtramos el arreglo eliminando por completo al usuario borrado
                                    empleados = empleados.filter(e => e.id != idProgramacion);

                                    // CRÍTICO: Guardamos la lista limpia en la memoria interna de jQuery
                                    $($ultimoBotonClickeado).data('empleados', empleados);

                                    // Respaldamos en el HTML duro
                                    $($ultimoBotonClickeado).attr('data-empleados', JSON.stringify(empleados));
                                }
                            }
                        } else {
                            alert(response.message || "Error al eliminar el empleado.");
                        }
                    })
                    .fail(function () {
                        alert("Error de comunicación con el servidor.");
                    });
            }
        });

        });
    </script>
}

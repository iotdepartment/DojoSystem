@model IEnumerable<TrainingsDashboard.Models.Areas>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
<link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" />

<div class="row">
    <h2 class="text-start">Areas <i class="bi bi-person-workspace"></i></h2>
    <hr class="border border-dark border-0 mb-4 opacity-100">
</div>

<div class="row">
    <div class="card mb-4 mt-3 p-4 rounded-3 shadow-lg">
        <div class="row mt-2">
            <div class="col-12">
                <button class="btn btn-success mb-3 rounded-pill" data-bs-toggle="modal" data-bs-target="#CreateAreaModal" onclick="openCreateAreaModal()">
                    <i class="bi bi-plus"></i>
                    Nueva Area
                </button>
            </div>
        </div>

        @if (Model != null && Model.Any())
        {
            <div class="row dt-row mt-3">
                <div class="table-responsive col-sm-12">
                    <table id="Areas" class="table table-striped table-bordered">
                        <thead class="table-dark">
                            <tr>
                                <th>ID</th>
                                <th>Área</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>@item.ID</td>
                                    <td>@item.Area</td>
                                    <td>
                                        <button type="button" class="btn btn-danger btn-sm rounded-pill"
                                                data-bs-toggle="modal"
                                                data-bs-target="#deleteConfirmModal"
                                                onclick="setDeleteId(@item.ID)">
                                            <i class="bi bi-trash"></i> Eliminar
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
        else
        {
            <p>No hay areas registradas.</p>
        }
    </div>
</div>

<div class="modal fade" id="CreateAreaModal" tabindex="-1" aria-labelledby="CreateAreaModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="CreateAreaModalLabel">Nueva Area</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <form id="CreateAreaForm" method="post" asp-controller="Areas" asp-action="Create">
                <div class="modal-body">

                    <div class="mb-3">
                        <label class="form-label">Nombre del area</label>
                        <input type="text" name="Nombre" class="form-control" required />
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="submit" class="btn btn-success rounded-pill">Guardar</button>
                    <button type="button" class="btn btn-secondary rounded-pill" data-bs-dismiss="modal">Cancelar</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="deleteConfirmModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title">Confirmar Eliminación</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>¿Seguro que deseas eliminar esta area?</p>
                <input type="hidden" id="deleteId" />
            </div>
            <div class="modal-footer">
                <button type="button" id="btnConfirmDelete" class="btn btn-danger">Eliminar</button>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>

    <script>
        $(document).ready(function () {

         $('#Areas').DataTable({
            pageLength: 10,
            order: [],
            responsive: true,
            autoWidth: false,
            language: {
                url: "https://cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json"
            }
        });

        });
    </script>

    <script>
    function setDeleteId(id) {
        document.getElementById("deleteId").value = id;
    }

    document.getElementById("btnConfirmDelete").addEventListener("click", function () {
        var id = document.getElementById("deleteId").value;

        $.ajax({
            url: '/Areas/Delete/' + id,
            type: 'POST',
            success: function () {

                $('#deleteConfirmModal').modal('hide');

                location.reload();
            },
            error: function () {
                alert("Error al eliminar el área.");
            }
        });
    });
</script>
}
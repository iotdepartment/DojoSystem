@model IEnumerable<TrainingsDashboard.Models.EntrenadorViewModel>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

<div class="container-fluid">
    <div class="card mb-4 p-3 border card-glass">
        <h2 class="m-0 text-start fw-bold"> Gestión de Entrenadores</h2>
    </div>
    <div class="card p-3 border card-glass">
        <div class="row mb-4 align-items-center">
            <div class="col-auto">
                <button class="btn btn-success shadow-lg rounded-pill px-4" data-bs-toggle="modal" data-bs-target="#ModalNuevoEntrenador">
                    <i class="fas fa-user-plus"></i> Nuevo Entrenador
                </button>
            </div>
            <div class="col">
                <input type="text" id="searchInput" class="form-control shadow-lg rounded-pill" placeholder="Buscar Entrenador...">
            </div>
        </div>
        <div class="row g-4 align-content-center" id="entrenadoresContainer">
            @foreach (var s in Model)
            {
                <div class="col-12 col-sm-6 col-md-4 col-lg-3 entrenador-card">
                    <div class="card card-area shadow-sm p-3 text-center position-relative">

                        <!-- Botón de engrane -->
                        <button class="settings-btn">
                            <i class="fas fa-cog"></i>
                        </button>

                        <!-- Menú flotante -->
                        <div class="settings-menu">
                            <a href="#" class="delete-entrenador text-danger" data-id="@s.EntrenadorID" data-nombre="@s.NombreEmpleado">
                                <i class="fas fa-trash"></i> Quitar Cargo
                            </a>
                        </div>

                        <img src="@s.Foto" class="profile-img mb-3" alt="Foto de @s.NombreEmpleado" style="width:100px; height:100px; object-fit:cover; border-radius: 50%;">

                        <div class="card-body">
                            <h5 class="card-title fw-bold target-name">@s.NombreEmpleado</h5>
                            <p class="card-text mb-1"><strong>No. Empleado:</strong> <span class="target-num">@s.NumeroEmpleado</span></p>
                            <p class="card-text mb-1"><strong>Área:</strong> @s.AreaNombre</p>
                            <p class="card-text mb-1"><strong>Turno:</strong> @s.TurnoNombre</p>
                            <p class="card-text mb-2"><strong>Supervisor:</strong> @s.SupervisorNombre</p>
                            <span class="badge bg-primary rounded-pill">Entrenador Activo</span>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<!-- MODAL: ASIGNAR NUEVO ENTRENADOR -->
<div class="modal fade" id="ModalNuevoEntrenador" tabindex="-1" aria-labelledby="ModalNuevoEntrenadorLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header bg-primary text-white rounded-top-4 p-3">
                <h5 class="modal-title fw-bold" id="ModalNuevoEntrenadorLabel">
                    <i class="fas fa-user-plus me-2"></i>Asignar Nuevo Entrenador
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="Crear" asp-controller="Entrenadores" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body p-4">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Selecciona el Empleado</label>
                        <select name="EmpleadoID" class="form-select rounded-pill" asp-items="ViewBag.ListaEmpleadosDisponibles" required>
                            <option value="" selected disabled>-- Elegir de la lista de personal --</option>
                        </select>
                        <div class="form-text text-muted mt-2">
                            <i class="fas fa-info-circle me-1"></i> Solo aparecen empleados activos que no posean el rango de entrenador actualmente.
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0 p-3 bg-light rounded-bottom-4">
                    <button type="submit" class="btn btn-success rounded-pill px-4 fw-bold">Promover a Entrenador</button>
                    <button type="button" class="btn btn-secondary rounded-pill px-4" data-bs-dismiss="modal">Cancelar</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- MODAL: CONFIRMAR ELIMINACIÓN -->
<div class="modal fade" id="ModalEliminarEntrenador" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header bg-danger text-white rounded-top-4 p-3">
                <h5 class="modal-title fw-bold"><i class="fas fa-exclamation-triangle me-2"></i>Quitar Cargo de Entrenador</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <p id="deleteMessage" class="fs-5 mb-1"></p>
                <input type="hidden" id="DeleteID">
            </div>
            <div class="modal-footer border-0 p-3 bg-light rounded-bottom-4">
                <button type="button" class="btn btn-danger rounded-pill px-4 fw-bold" id="btnConfirmDelete">Quitar Cargo</button>
                <button type="button" class="btn btn-secondary rounded-pill px-4" data-bs-dismiss="modal">Cancelar</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://jquery.com"></script>

    <!-- Barra de busqueda -->
    <script>
        const container = document.querySelector(".row.g-4");
        const originalCards = Array.from(container.children);

        document.getElementById("searchInput").addEventListener("keyup", function () {
            var filter = this.value.toLowerCase();
            var cards = Array.from(container.querySelectorAll(".col-12, .col-sm-6, .col-md-4, .col-lg-3"));

            if (filter.trim() !== "") {
                // Filtrar las que coinciden
                var matching = cards.filter(card => card.innerText.toLowerCase().includes(filter));

                // Ocultar las que no coinciden
                cards.forEach(card => {
                    if (!matching.includes(card)) {
                        card.style.display = "none";
                    } else {
                        card.style.display = "";
                    }
                });

                // Mover las coincidentes al inicio
                matching.forEach(card => {
                    container.insertBefore(card, container.firstChild);
                });
            } else {
                // Restaurar todas las cards y su orden original
                container.innerHTML = "";
                originalCards.forEach(card => {
                    card.style.display = "";
                    container.appendChild(card);
                });
            }
        });

    </script>

    <!-- Boton desplegable de tuerca -->
    <script>
        document.addEventListener("click", function (e) {
            const btn = e.target.closest(".settings-btn");
            const menus = document.querySelectorAll(".settings-menu");

            if (btn) {
                const menu = btn.parentElement.querySelector(".settings-menu");

                // Si el menú ya está visible, lo cerramos
                if (menu.style.display === "block") {
                    menu.style.display = "none";
                } else {
                    // Cerramos todos los demás menús
                    menus.forEach(m => m.style.display = "none");
                    // Abrimos el menú del engrane clicado
                    menu.style.display = "block";
                }

                e.stopPropagation();
            } else {
                // Cerrar todos los menús si se hace clic fuera
                menus.forEach(m => m.style.display = "none");
            }
        });
    </script>

    <!-- Modal para eliminar entrenador -->
    <script>
        $(document).ready(function () {
            $('.delete-entrenador').on('click', function (e) {
                e.preventDefault();
                var id = $(this).data('id');
                var nombre = $(this).data('nombre');

                $('#DeleteID').val(id);
                $('#deleteMessage').html('¿Estás seguro de que deseas quitar el cargo de entrenador a: <strong class="text-danger">' + nombre + '</strong>?');

                var deleteModal = new bootstrap.Modal(document.getElementById('ModalEliminarEntrenador'));
                deleteModal.show();
            });

            $('#btnConfirmDelete').on('click', function () {
                var entId = $('#DeleteID').val();

                $.ajax({
                    url: '/Entrenadores/Eliminar',
                    type: 'POST',
                    data: { id: entId },
                    success: function () {
                        window.location.reload();
                    },
                    error: function () {
                        alert('Error al intentar revocar el rango del entrenador.');
                    }
                });
            });
        });
    </script>
}

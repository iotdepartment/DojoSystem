@model IEnumerable<dynamic>

<link rel="stylesheet" href="https://cloudflare.com">

<div class="container-fluid">
    <div class="card rounded rounded-3 title-glass p-3">
        
        <!-- Encabezado -->
        <div class="card mb-4 p-3 shadow-lg border-1 rounded-pill title-glass">
            <h2 class="m-0 text-start fw-bold">Métricas y Porcentajes de Asistencia</h2>
        </div>

        <!-- Panel de Filtros Colectivos (Ajustado a PizarronController) -->
        <div class="row mb-4 align-items-end bg-light p-3 rounded-4 mx-1 border">
            <div class="col-12 mb-2">
                <span class="fw-bold text-secondary small uppercase"><i class="fas fa-filter me-1"></i> Segmentar Estadísticas</span>
            </div>
            <form method="get" action="@Url.Action("DashboardAsistencia", "Pizarron")" id="formFiltrosDashboard" class="row g-3 w-100 m-0">
                
                <!-- Filtro por Área -->
                <div class="col-12 col-md-4">
                    <label class="form-label small fw-bold text-muted">Filtrar por Área:</label>
                    <select name="areaId" class="form-select rounded-pill shadow-sm change-submit">
                        <option value="">-- Todas las Áreas --</option>
                        @foreach (var item in ViewBag.ListaAreas as List<SelectListItem>)
                        {
                            <!option value="@item.Value" @(item.Selected ? "selected" : "")>@item.Text</!option>
                        }
                    </select>
                </div>

                <!-- Filtro por Turno -->
                <div class="col-12 col-md-4">
                    <label class="form-label small fw-bold text-muted">Filtrar por Turno:</label>
                    <select name="turnoId" class="form-select rounded-pill shadow-sm change-submit">
                        <option value="">-- Todos los Turnos --</option>
                        @foreach (var item in ViewBag.ListaTurnos as List<SelectListItem>)
                        {
                            <!option value="@item.Value" @(item.Selected ? "selected" : "")>@item.Text</!option>
                        }
                    </select>
                </div>

                <!-- Botón de Limpieza Completa -->
                <div class="col-12 col-md-4 text-md-end">
                    <a href="@Url.Action("DashboardAsistencia", "Pizarron")" class="btn btn-outline-secondary rounded-pill px-4 shadow-sm fw-bold">
                        <i class="fas fa-undo-alt me-1"></i> Restablecer
                    </a>
                </div>
            </form>
        </div>

        <!-- Rejilla Dinámica de Tarjetas (Cards) -->
        <div class="row g-4">
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    string colorBarra = "bg-danger"; 
                    if (item.PorcentajeAsistencia >= 85) { colorBarra = "bg-success"; } 
                    else if (item.PorcentajeAsistencia >= 50) { colorBarra = "bg-warning text-dark"; } 

                    <div class="col-12 col-sm-6 col-md-4 col-lg-3">
                        <div class="card h-100 shadow-sm p-3 border-0 rounded-4 bg-white d-flex flex-column justify-content-between">
                            <div>
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <div class="avatar bg-primary-subtle text-primary rounded-3 p-2">
                                        <i class="fas fa-chart-pie fa-lg"></i>
                                    </div>
                                    <div class="text-end">
                                        <h3 class="fw-bold m-0 text-dark">@item.PorcentajeAsistencia%</h3>
                                        <small class="text-muted extra-small fw-bold">CUMPLIMIENTO</small>
                                    </div>
                                </div>

                                <div class="mb-3">
                                    <h6 class="fw-bold text-primary mb-1 text-truncate" title="@item.Nombre">@item.Nombre</h6>
                                    <p class="text-muted small m-0 text-truncate-2" style="font-size: 0.8rem; height: 38px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                                        @(string.IsNullOrEmpty(item.Descripcion) ? "Sin descripción registrada." : item.Descripcion)
                                    </p>
                                </div>

                                <div class="mb-3">
                                    <div class="progress rounded-pill shadow-inner" style="height: 10px;">
                                        <div class="progress-bar progress-bar-striped progress-bar-animated @colorBarra" 
                                             role="progressbar" 
                                             style="width: @item.PorcentajeAsistencia%" 
                                             aria-valuenow="@item.PorcentajeAsistencia" 
                                             aria-valuemin="0" 
                                             aria-valuemax="100"></div>
                                    </div>
                                </div>
                            </div>

                            <div class="border-top pt-2 mt-2 bg-light px-2 py-1 rounded border">
                                <div class="d-flex justify-content-between align-items-center extra-small mb-1" style="font-size: 0.8rem;">
                                    <span class="text-muted"><i class="fas fa-user-check me-1 text-success"></i> Asistieron:</span>
                                    <span class="fw-bold text-dark">@item.Asistieron</span>
                                </div>
                                <div class="d-flex justify-content-between align-items-center extra-small" style="font-size: 0.8rem;">
                                    <span class="text-muted"><i class="fas fa-users me-1 text-secondary"></i> Totales Agendados:</span>
                                    <span class="fw-bold text-dark">@item.Convocados</span>
                                </div>
                            </div>

                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12 text-center p-5 text-muted">
                    <i class="fas fa-folder-open fa-3x mb-3 text-secondary"></i>
                    <h5 class="fw-bold">Sin datos para mostrar</h5>
                    <p class="small m-0">No se encontraron registros de entrenamientos que coincidan con el área o turno seleccionados.</p>
                </div>
            }
        </div>

    </div>
</div>

@section Scripts {
    <script src="https://jquery.com"></script>
    <script>
        $(document).ready(function () {
            // Envío automático al cambiar de opción
            $('.change-submit').on('change', function () {
                $('#formFiltrosDashboard').submit();
            });
        });
    </script>
}

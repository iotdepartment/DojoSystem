@model List<TrainingsDashboard.Models.Areas>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">


<div class="container-fluid">
    <!-- Encabezado Principal -->
    <div class="card mb-4 p-3 shadow-lg border card-glass">
        <h2 class="m-0 text-start fw-bold">Cumplimiento de Capacitación por Área y Turno</h2>
    </div>
    <div class="card card-glass border bg-white p-3">

        <!-- CONTROL SUPERIOR: NAVEGADOR DE ÁREAS Y TURNOS AUTOMÁTICO -->
        <div class="card mb-4 p-3 border card-glass">
            <div class="row align-items-center">
                <!-- Botón Anterior -->
                <div class="col-auto">
                    <button type="button" id="btnPrevArea" class="btn btn-outline-primary rounded-circle p-2" style="width: 45px; height: 45px;">
                        <i class="fas fa-chevron-left"></i>
                    </button>
                </div>

                <!-- Indicador de Área Activa -->
                <div class="col text-center">
                    <h3 id="txtAreaActiva" class="fw-extrabold text-primary m-0 area-badge-nav">Cargando área...</h3>
                </div>

                <!-- Botón Siguiente -->
                <div class="col-auto">
                    <button type="button" id="btnNextArea" class="btn btn-outline-primary rounded-circle p-2" style="width: 45px; height: 45px;">
                        <i class="fas fa-chevron-right"></i>
                    </button>
                </div>
            </div>

            <!-- Barra inferior de controles multimedia e Indicador de Turno -->
            <div class="d-flex justify-content-between align-items-center mt-3 pt-2 border-top">
                <div>
                    <button type="button" id="btnPlayPause" class="btn btn-sm btn-success rounded-pill px-3 fw-bold shadow-sm">
                        <i class="fas fa-pause me-1"></i> Pausar Rotación
                    </button>
                </div>

                <!-- INDICADOR DINÁMICO DE TURNO ACTIVADO POR JAVASCRIPT (IDs Corregidos según tu BD) -->
                <div class="d-flex gap-2" id="contenedorFiltroVisualTurnos">
                    <span class="badge bg-secondary badge-turno-activo opacity-50" id="badge-t-2">Primer Turno</span>
                    <span class="badge bg-secondary badge-turno-activo opacity-50" id="badge-t-3">Segundo Turno</span>
                    <span class="badge bg-secondary badge-turno-activo opacity-50" id="badge-t-4">Tercer Turno</span>
                </div>
            </div>
        </div>

        <!-- SECCIÓN INFERIOR: CONTENEDOR DINÁMICO DE CARDS -->
        <div class="row g-4" id="contenedorTarjetasMétricas">
            <!-- Cargado dinámicamente mediante AJAX -->
        </div>

    </div>
</div>

@section Scripts {
    <script src="https://jquery.com"></script>
    <script>
        $(document).ready(function () {
            const areas = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Select(a => new { id = a.ID, nombre = a.Nombre })));

            let areaIndice = 0;
            let turnoActual = 2; // AJUSTE CRÍTICO: Inicia en ID 2 (Primer Turno) según tu BD
            let temporizadorCiclo = null;
            let rotacionActiva = true;
            const tiempoSubIntervalo = 10000; // 10 segundos por Turno

            const $txtArea = $('#txtAreaActiva');
            const $contenedorCards = $('#contenedorTarjetasMétricas');
            const $btnPlayPause = $('#btnPlayPause');
            const $btnPrev = $('#btnPrevArea');
            const $btnNext = $('#btnNextArea');

            if (areas.length === 0) {
                $txtArea.text("No hay áreas con datos registrados.");
                $contenedorCards.html('<div class="col-12 text-center p-5 text-muted"><p>No se encontraron entrenamientos programados activos.</p></div>');
                return;
            }

            function cargarMétricasKiosco() {
                const area = areas[areaIndice];

                // 1. Actualizar el título de la pantalla
                $txtArea.text(area.nombre);

                // 2. Resaltar visualmente qué turno se está evaluando usando tus IDs reales (2, 3, 4)
                $('.badge-turno-activo').removeClass('bg-primary text-white').addClass('bg-secondary opacity-50');
                $(`#badge-t-${turnoActual}`).removeClass('bg-secondary opacity-50').addClass('bg-primary text-white');

                // Obtener el nombre legible del turno para los mensajes de la tarjeta
                let nombreTurnoTexto = "Primer Turno";
                if(turnoActual === 3) nombreTurnoTexto = "Segundo Turno";
                if(turnoActual === 4) nombreTurnoTexto = "Tercer Turno";

                // 3. Mostrar spinner de carga rápida
                $contenedorCards.html('<div class="col-12 text-center p-5"><div class="spinner-border text-primary spinner-border-sm" role="status"></div><small class="ms-2 text-muted">Cargando métricas...</small></div>');

                $.ajax({
                    url: '/Pizarron/ObtenerMetricasPorArea',
                    type: 'GET',
                    data: { areaId: area.id, turnoId: turnoActual },
                    success: function (data) {
                        $contenedorCards.empty();

                        if (data.length === 0) {
                            $contenedorCards.html(`
                                <div class="col-12 text-center p-5 text-muted">
                                    <i class="fas fa-folder-open fa-2x mb-2 text-secondary"></i>
                                    <h6 class="fw-bold">Sin registros</h6>
                                    <p class="small m-0">El área de <strong>${area.nombre}</strong> no registra datos en el <strong>${nombreTurnoTexto}</strong>.</p>
                                </div>
                            `);
                            return;
                        }

                        data.forEach(item => {
                            let colorBarra = "bg-danger";
                            if (item.porcentajeAsistencia >= 85) { colorBarra = "bg-success"; }
                            else if (item.porcentajeAsistencia >= 50) { colorBarra = "bg-warning text-dark"; }

                            const cardHtml = `
                                <div class="col-12 col-sm-6 col-md-4 col-lg-3">
                                    <div class="card h-100 p-3 border card-glass bg-white d-flex flex-column justify-content-between card-metric">
                                        <div>
                                            <div class="d-flex justify-content-between align-items-start mb-2">
                                                <div class="avatar bg-primary-subtle text-primary rounded-3 p-1 px-2 small fw-bold">
                                                    <i class="fas fa-clock"></i> ${turnoActual === 2 ? 'T1' : turnoActual === 3 ? 'T2' : 'T3'}
                                                </div>
                                                <div class="text-end">
                                                    <h4 class="fw-bold m-0 text-dark">${item.porcentajeAsistencia}%</h4>
                                                </div>
                                            </div>
                                            <div class="mb-2">
                                                <h6 class="fw-bold text-primary mb-1 text-truncate" title="${item.nombre}">${item.nombre}</h6>
                                                <p class="text-muted small m-0 text-truncate" style="font-size: 0.75rem;">${item.descripcion}</p>
                                            </div>
                                            <div class="progress rounded-pill progress-inner" style="height: 8px;">
                                                <div class="progress-bar progress-bar-striped progress-bar-animated ${colorBarra}" style="width: ${item.porcentajeAsistencia}%"></div>
                                            </div>
                                        </div>
                                        <div class="border-top pt-2 mt-2 bg-light px-2 py-1 rounded border" style="font-size: 0.75rem;">
                                            <div class="d-flex justify-content-between">
                                                <span class="text-muted">Asistieron:</span><span class="fw-bold">${item.asistieron}</span>
                                            </div>
                                            <div class="d-flex justify-content-between">
                                                <span class="text-muted">Convocados:</span><span class="fw-bold">${item.convocados}</span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            `;
                            $contenedorCards.append(cardHtml);
                        });
                    },
                    error: function () {
                        $contenedorCards.html('<div class="col-12 text-center p-4 text-danger"><p class="small m-0">Error de conexión.</p></div>');
                    }
                });
            }

            // LÓGICA REFACTORIZADA PARA SEGUIR LA SECUENCIA DE IDs (2 -> 3 -> 4)
            function ejecutarCicloKiosco() {
                destruirCiclo();
                temporizadorCiclo = setInterval(function () {
                    if (rotacionActiva) {
                        turnoActual++; // Incrementa de 2 a 3, luego a 4

                        if (turnoActual > 4) { // AJUSTE CRÍTICO: Si supera el ID 4 (Tercer Turno), se reinicia
                            turnoActual = 2;   // Regresa al ID 2 (Primer Turno)
                            areaIndice = (areaIndice + 1) % areas.length; // Cambia de área
                        }

                        cargarMétricasKiosco();
                    }
                }, tiempoSubIntervalo);
            }

            function destruirCiclo() {
                if (temporizadorCiclo) clearInterval(temporizadorCiclo);
            }

            // CONTROLES MANUALES (Saltan directo al Primer Turno [ID 2] del área seleccionada)
            $btnNext.on('click', function () {
                turnoActual = 2;
                areaIndice = (areaIndice + 1) % areas.length;
                cargarMétricasKiosco();
                if (rotacionActiva) ejecutarCicloKiosco();
            });

            $btnPrev.on('click', function () {
                turnoActual = 2;
                areaIndice = (areaIndice - 1 + areas.length) % areas.length;
                cargarMétricasKiosco();
                if (rotacionActiva) ejecutarCicloKiosco();
            });

            $btnPlayPause.on('click', function () {
                rotacionActiva = !rotacionActiva;
                if (rotacionActiva) {
                    $(this).removeClass('btn-warning text-dark').addClass('btn-success').html('<i class="fas fa-pause me-1"></i> Pausar Rotación');
                    ejecutarCicloKiosco();
                } else {
                    $(this).removeClass('btn-success').addClass('btn-warning text-dark').html('<i class="fas fa-play me-1"></i> Reanudar Transición');
                    destruirCiclo();
                }
            });

            // EJECUCIÓN INICIAL
            cargarMétricasKiosco();
            ejecutarCicloKiosco();
        });
    </script>
}


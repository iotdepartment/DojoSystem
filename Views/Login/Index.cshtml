@{
    Layout = "_LoginLayout";
}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">

<div class="d-flex justify-content-center align-items-center" style="min-height: 80vh;">
    <div class="card shadow-lg border-0 rounded-4" style="width: 350px;">
        <div class="card-body  p-4 text-center">

            <div class="bg-tertiary rounded-4 d-inline-block mb-3">
                <img src="/images/Logo.png" alt="Toyoda Gosei" class="img-fluid" style="max-height: 70px;" />
            </div>

            <h4 class="fw-bold mb-4">New Programs Orders System</h4>

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger rounded-4">
                    @TempData["Error"]
                </div>
            }

            <form method="post" action="/Login/Index">
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <div class="input-group rounded-4">
                        <span class="input-group-text"><i class="bi bi-person"></i></span>
                        <input type="text" name="UserName" class="form-control rounded-end" placeholder="User" required />
                    </div>
                </div>

                <div class="mb-3">
                    <div class="input-group rounded-4">
                        <span class="input-group-text"><i class="bi bi-lock"></i></span>
                        <input type="password" name="password" class="form-control rounded-end" placeholder="Password" required />
                    </div>
                </div>

                <button type="submit" class="btn btn-dark w-100 rounded-pill">
                    <i class="bi bi-box-arrow-in-right"></i> Login
                </button>
            </form>

        </div>
        <div class="card-footer text-muted text-center small">
            © TGRMX Iot Department 2026 (Ver. 0.32726)
        </div>
    </div>
</div>